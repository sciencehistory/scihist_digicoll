<%# hacky and also not accessible way to reload every 3 seconds until we are done, temporary %>
<% unless @conversation.complete? %>
  <%= content_for(:head) do %>
    <meta http-equiv="refresh" content="4">
  <% end %>
<% end %>

<div class="text-page">
  <h2>Use this software-powered research tool to <span class="emphasis-color">ask about</span> the contents of our <span class="emphasis-color">Oral History</span> collections</h2>

  <p>
    <%= link_to new_oral_history_ai_conversation_path do %>
      <i class="fa fa-undo" aria-hidden="true"></i>
      Ask another question
    <% end %>
  </p>

  <div class="alert alert-warning mb-4 mt-4">
    <span class="fw-bold">Q:</span> <%=  @conversation.question %>
  </div>


  <%# have to match the DOM of the Blacklight search results filters. Fragile? Maybe. %>
  <div id="appliedParams" class="constraints-container">
    <span class="applied-filter">
      <span class="constraint-value btn btn-outline-secondary">
          <span class="filter-name">Including</span>
          <span class="filter-value">
            <%= @conversation.search_params&.dig("access_limit").presence ? t(@conversation.search_params["access_limit"], scope: "oral_history.access_limit") : "All" %>
          </span>
      </span>
    </span>
  </div>


  <div class="d-flex justify-content-end mb-3">
    <span class="ai-conversation-date fw-semibold" data-iso8601="<%= @conversation.request_sent_at&.iso8601 %>">
        Prepared <%= l(@conversation.request_sent_at&.to_date || @conversation.created_at.to_date, format: :long) %>
    </span>
  </div>

  <ul class="ai-icon-bullet">
    <% if @chunks_used = @conversation.chunks_used.present? && @conversation.chunks_used.collect { |hash| hash["oral_history_content_id"] }.uniq.count %>
      <li class="ai-checkmark text-muted">Answer will use passages from <%= @chunks_used %> oral history transcripts identified as most useful to the topic.</li>
    <% else %>
      <li class="ai-circle-progress text-muted">
        Identifying passages useful to the topic…
      </li>
    <% end %>
  </ul>


  <% if !@conversation.complete? %>
    <div class="d-flex align-items-center text-muted">
      <i class="fa fa-circle-o-notch fa-spin me-2" aria-hidden="true"></i>
      Working…
    </div>
  <% elsif @conversation.status_error? %>
    <div class="alert alert-danger">
      Sorry, an error happened!  Error object <%= @conversation.external_id %>.
    </div>
  <% else %>
    <%# some legacy display for old formats %>
    <% if @conversation.answer_json.has_key?("narrative") && @conversation.answer_json.has_key?("footnotes") %>
      <%= render OralHistory::AiConversationDisplayJan2026.new(@conversation)%>
    <% else %>
      <%= render OralHistory::AiConversationDisplayComponent.new(@conversation)%>
    <% end %>
  <% end %>


</div>
