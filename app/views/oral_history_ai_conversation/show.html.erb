<%# hacky and also not accessible way to reload every 3 seconds until we are done, temporary %>
<% unless @conversation.complete? %>
  <%= content_for(:head) do %>
    <meta http-equiv="refresh" content="4">
  <% end %>
<% end %>

<div class="ai-conversation-banner">
  <div class="banner-wrapper">
    <h1 class="brand-alt-h1">
      Bot-Assisted Oral History Search
    </h1>
  </div>
</div>

<div class="text-page">
  <p>
    <%= link_to new_oral_history_ai_conversation_path do %>
      <i class="fa fa-undo" aria-hidden="true"></i>
      Ask another question
    <% end %>
  </p>

  <div class="alert alert-warning mb-4 mt-4">
    <span class="fw-bold">Q:</span> <%=  @conversation.question %>
  </div>


  <%# have to match the DOM of the Blacklight search results filters. Fragile? Maybe. %>
  <div id="appliedParams" class="constraints-container">
    <span class="applied-filter">
      <span class="constraint-value btn btn-outline-secondary">
          <span class="filter-name">Including</span>
          <span class="filter-value">
            <%= @conversation.search_params&.dig("access_limit").presence ? t(@conversation.search_params["access_limit"], scope: "oral_history.access_limit") : "All" %>
          </span>
      </span>
    </span>
  </div>

  <div class="d-flex justify-content-end mb-3">
    <span class="ai-conversation-date text-muted" data-iso8601="<%= @conversation.request_sent_at&.iso8601 %>">
        Prepared <%= l(@conversation.request_sent_at&.to_date || @conversation.created_at.to_date, format: :long) %>
    </span>
  </div>

  <%# legacy display for old formats, only on complete, can't be JS updated %>
  <% if @conversation.complete? &&
        @conversation.answer_json.has_key?("narrative") &&
        @conversation.answer_json.has_key?("footnotes") %>
      <%= render OralHistory::AiConversationDisplayJan2026.new(@conversation)%>
  <% else %>
      <%= render OralHistory::AiConversationDisplayComponent.new(@conversation)%>
  <% end %>

  <details class="ai-conversation-help mt-5">
    <summary class="text-link">Some technical details about how this tool works</summary>

    <div class="p-3">
      <%= render "technical_details" %>
   </div>
  </details>

  <div class="alert alert-danger">
    <i class="fa fa-exclamation-triangle" aria-hidden="true"></i>
    This is currently a <b>beta</b> under active research & development, available only to internal Science History Institute users.
  </div>
</div>
