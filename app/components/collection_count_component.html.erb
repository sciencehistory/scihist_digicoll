 <% if can_see_unpublished_records? %>
      <%= "#{number_with_delimiter(public_work_count)}
      public #{'work'.pluralize(public_work_count)}

      containing #{number_with_delimiter(public_asset_count)}
      #{'asset'.pluralize(public_asset_count)};

      <br/>
      #{number_with_delimiter(all_work_count)} total works containing 
      containing #{number_with_delimiter(all_asset_count)}
      #{'asset'.pluralize(all_asset_count)}.
      ".html_safe %>
  <% else %>
    <%= "#{number_with_delimiter(public_work_count)} #{'item'.pluralize(public_work_count)}" %>
  <% end %>
